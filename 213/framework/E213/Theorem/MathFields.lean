/-
  E213/Theorem/MathFields.lean — 수학 분야들의 213 수

  각 분야가 213의 어떤 연산에 대응하는가.
  비용 = 순서를 얼마나 넣는가.
-/
import E213.Normalize
open Expr

-- ═══ 분야 → 213 수 매핑 ═══

structure Field213 where
  name : String
  cost : Nat           -- 순서 비용
  expr_213 : String    -- 213 산술 표현
  operation : String   -- 주 연산
  deriving Repr

def fields : List Field213 := [
  -- cost 0: 213 자체
  ⟨"213 (판정)",          0, "e₁",    "판정 (같다/다르다)"⟩,

  -- cost 1: 경계 연산
  ⟨"집합론 (소속)",        1, "1",     "∈ (소속 판정)"⟩,
  ⟨"위상수학 (열림/닫힘)",  1, "1",     "경계 ∂"⟩,

  -- cost 2: 구분 연산
  ⟨"논리학",              2, "e₂",    "참/거짓 구분"⟩,
  ⟨"범주론",              2, "e₂",    "사상 합성 (방향)"⟩,
  ⟨"선형대수",            2, "e₂",    "차원 (구분 축 수)"⟩,

  -- cost 3: 창발 연산
  ⟨"군론",                3, "e₃",    "결합+항등+역원"⟩,
  ⟨"정수론 (초등)",       3, "e₃",    "소수 (분해 불가능)"⟩,
  ⟨"조합론",              3, "e₃",    "세기 (C(n,k))"⟩,
  ⟨"기하학 (유클리드)",    3, "e₃",    "3차원 공간"⟩,

  -- cost 5: σ₁ = e₂+e₃
  ⟨"대수학",              5, "e₂+e₃", "다항식 (변수+연산)"⟩,
  ⟨"페아노 산술",         5, "e₂+e₃", "succ 순서 + 귀납"⟩,
  ⟨"증명론",              5, "e₂+e₃", "증명 구조"⟩,

  -- cost 6: σ₂ = e₂×e₃
  ⟨"해석적 정수론",       6, "e₂×e₃", "L-함수 (해석+수론)"⟩,
  ⟨"대수기하",            6, "e₂×e₃", "다양체 (대수+기하)"⟩,
  ⟨"ZFC",                 6, "e₂×e₃", "소속+무한"⟩,

  -- cost 7+: 초과
  ⟨"해석학 (ε-δ)",        7, "e₂×e₃+1","극한 (순서+측도+연속)"⟩,
  ⟨"편미분방정식",        8, "e₂³",   "연속+비선형+경계조건"⟩,
  ⟨"확률론",              7, "e₂×e₃+1","측도+조건부"⟩
]

-- ═══ 비용별 분류 ═══
#eval fields.filter (·.cost ≤ 3) |>.map (·.name)
-- 비용 ≤ 3: 순수 구조. 쉬움.

#eval fields.filter (fun f => f.cost > 3 && f.cost ≤ 5) |>.map (·.name)
-- 비용 4-5: 구조+순서. 경계선.

#eval fields.filter (·.cost > 5) |>.map (·.name)
-- 비용 > 5: 순서 지배. 어려움.

-- ═══ 213 산술로 비용 표현 ═══
-- 0 = e₁ (경계)
-- 1 = e₁ (1의 값)
-- 2 = e₂ (구분)
-- 3 = e₃ (창발)
-- 5 = e₂+e₃ = σ₁ (합)
-- 6 = e₂×e₃ = σ₂ (곱)
-- 7 = e₂×e₃+e₁ = σ₂+1
-- 8 = e₂³ = 구분의 세제곱
-- 9 = e₃² = 창발의 제곱

-- 모든 비용이 {e₁, e₂, e₃}의 산술 조합.
-- 비용 자체가 213 내부.

-- ═══ 패턴 ═══
-- 비용 = e₂^a × e₃^b (단항식) 형태:
-- 0 = e₂⁰e₃⁰ (상수)
-- 2 = e₂¹ (구분 1회)
-- 3 = e₃¹ (창발 1회)
-- 4 = e₂² (구분 2회)
-- 6 = e₂¹e₃¹ (구분×창발)
-- 8 = e₂³ (구분 3회)
-- 9 = e₃² (창발 2회)

-- 비용 5, 7 = 합(σ₁, σ₂+1). 단항식 아닌 다항식.
-- 합 = plus = 서로 다른 종류의 비용 결합.
-- 5 = 구분 + 창발 (두 종류 혼합).
-- 7 = 구분×창발 + 경계 (곱 + 잔여).

-- ═══ 수학 분야의 어려움 ═══
-- 가장 어려운 분야 = 비용 최대 = PDE (8 = e₂³).
-- "구분을 세 번 반복": 공간미분(1차) × 시간미분(2차) × 비선형(3차).
-- 이것이 NS가 어려운 이유의 213 버전.

-- 가장 쉬운 분야 = 비용 최소 = 판정 (0 = e₁).
-- "구분 0회": 같다/다르다만.
