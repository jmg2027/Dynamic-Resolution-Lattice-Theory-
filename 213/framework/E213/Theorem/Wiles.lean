/-
  E213/Theorem/Wiles.lean — Wiles의 3-5 trick을 2한다

  다니야마-시무라 증명의 핵심 소수: 3, 5.
  GL(2) = 2×2 행렬.
  이것들이 213의 원자인가?
-/
import E213.Normalize
open Expr

-- ═══ 사실 확인 ═══

-- 3-5 trick의 소수: 3과 5
-- 3 = e₃ (eval(2,3) 하에서)
-- 5 = e₂ + e₃ = σ₁ = d
#eval exprEval e₃ 2 3                         -- 3
#eval exprEval (plus e₂ e₃) 2 3               -- 5

-- GL(2): 2×2 행렬. 2 = e₂.
#eval exprEval e₂ 2 3                         -- 2

-- 3과 5는 가산 원자인가?
def isAtom (n : Nat) : Bool :=
  n >= 2 && !(List.range (n-1) |>.drop 2 |>.any
    fun a => n - a >= 2)

#eval isAtom 3     -- true. 3은 가산 원자.
#eval isAtom 5     -- false. 5 = 2+3, 원자 아님. 합성수(가산).

-- 5는 원자가 아니라 원자의 합.
-- 5 = 2 + 3 = e₂ + e₃ = σ₁.
-- Wiles가 3에서 시작해서 5로 간 것 =
-- e₃(원자)에서 시작해서 σ₁(원자의 합)으로 확장.

-- ═══ 213 구조 ═══

-- Wiles의 환원:
--   ∀ 타원곡선 (무한) → mod 3 확인 (유한) → mod 5로 확장 → 리프팅
-- 213으로:
--   ∀ (순서 비용) → e₃ (원자) → σ₁ (원자 합) → 복원

-- mod p에서의 GL(2) 크기
-- |GL(2, 𝔽_p)| = (p²-1)(p²-p) = p(p-1)²(p+1)
def gl2_size (p : Nat) : Nat := p * (p-1) * (p-1) * (p+1)

#eval gl2_size 2   -- 2×1×1×3 = 6 = σ₂ = 2×3
#eval gl2_size 3   -- 3×2×2×4 = 48 = 2⁴×3
#eval gl2_size 5   -- 5×4×4×6 = 480 = 2⁵×3×5

-- |GL(2, 𝔽₂)| = 6 = σ₂ = e₂ × e₃.
#eval gl2_size 2 == 2 * 3                     -- true

-- ═══ 다른 큰 증명의 핵심 수 ═══

-- 페르마: a^n + b^n = c^n. n ≥ 3. 핵심 수: 3 (= e₃).
-- 푸앵카레: 3차원 다양체. 핵심 수: 3 (= e₃).
-- BSD: 타원곡선 (= 차수 3 곡선 in P²). 핵심 수: 3, 2.
-- 호지: 복소 다양체. ℂ = dim 2. 핵심 수: 2 (= e₂).

-- 핵심 소수 빈도
-- 2: 모든 곳 (ℂ, GL(2), 이진 구분)
-- 3: 거의 모든 곳 (원자, 고정점, 3차원)
-- 5: 와일스 (3-5 trick), d=5
-- 그 외: 드물거나 213의 합성

-- ═══ 판정 ═══
-- "Wiles의 3-5 trick에 사용된 수가 213의 원자/합인가?"
#eval isAtom 2                                 -- true (e₂)
#eval isAtom 3                                 -- true (e₃)
#eval (5 : Nat) == 2 + 3                       -- true (σ₁)
#eval gl2_size 2 == 2 * 3                      -- true (σ₂)
-- 전부 213의 수.

-- [해석] 이것이 구조적인지 우연인지는 미결정.
-- [213] 2, 3, 5, 6이 전부 213의 산술에서 나오는 것은 판정됨.
