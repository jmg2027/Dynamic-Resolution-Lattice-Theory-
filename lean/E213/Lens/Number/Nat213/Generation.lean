import E213.Lens.Number.Nat213.Raw
import E213.Lens.LensCore
import E213.Lens.Initiality

/-!
# Lens.Number.Nat213.Generation ‚ÄĒ ‚Ąē‚āä is the leaves-Lens reading of iterated distinguishing (‚ąÖ-axiom)

The **descent leg**'s generation headline (`research-notes/frontiers/the_descent_leg.md`): the
positive naturals are not posited and not merely an "ergonomic parallel" to a Lens form ‚ÄĒ they are
*generated by the act of distinguishing* and *read off by the canonical leaves-Lens*:

  - the start is the atom: `one := Raw.a`;
  - the successor **is** the distinguishing operation ‚ÄĒ `succ n := slashOrSelf n Raw.b`
    (`succ_is_distinguishing`), wrapping `n` by a `slash` against the other atom `b`;
  - the count **is** the canonical Lens ‚ÄĒ `value = Lens.leaves.view` (`value_eq_leaves`), the
    `‚ü®1,1,(¬∑+¬∑)‚ü©` catamorphism, *not* a bespoke projection (this turns `Raw.lean`'s comment into a
    theorem).

So `Lens.leaves.view (numeral n) = n + 1` (`leaves_numeral`): the positive natural `n+1` is exactly
the canonical leaves-Lens reading of the Raw built by `n`-fold `slash`-against-`b` from the atom `a`.
**‚Ąē‚āä = the count-Lens reading of iterated self-distinguishing** ‚ÄĒ generation, not parallel.  This is
the corrected thesis at the foundation of arithmetic: number is the distinguishing's unfolding, read
by a Lens.  ‚ąÖ-axiom.
-/

namespace E213.Lens.Number.Nat213.Generation

open E213.Theory (Raw)
open E213.Theory.Raw.Endomorphic (slashOrSelf)
open E213.Lens.Number.Nat213.Raw (one succ numeral value value_numeral)
open E213.Lens.Initiality

/-- The local leaf-count `value` **is** the canonical leaves-Lens reading
    `Lens.leaves.view` (`Lens.leaves = ‚ü®1,1,(¬∑+¬∑)‚ü©`, the catamorphism).  `Raw.lean`'s comment as a
    theorem: the count is the canonical Lens, not a bespoke projection. -/
theorem value_eq_leaves (r : Raw) : value r = Lens.leaves.view r := rfl

/-- The successor on the Raw chain **is** the act of distinguishing: `succ n` wraps `n` by a `slash`
    against the other atom `b`.  Number's `+1` is a distinguishing event. -/
theorem succ_is_distinguishing (n : Raw) : succ n = slashOrSelf n Raw.b := rfl

/-- The canonical leaves-Lens reading of the `n`-fold iterated distinguishing is `n + 1`. -/
theorem leaves_numeral (n : Nat) : Lens.leaves.view (numeral n) = n + 1 := by
  rw [‚Üź value_eq_leaves]; exact value_numeral n

/-- ‚ėÖ‚ėÖ‚ėÖ **The count is the *forced* reading** ‚ÄĒ initiality (`Lens.view_unique`) at the arithmetic
    level.  *Any* `g : Raw ‚Üí Nat` that interprets each atom as `1` and a distinguishing (`slash`) as
    addition is **identically** the leaf-count `value`.  So ‚Ąē-counting is not one choice among
    readings of the distinguishing ‚ÄĒ fixing "atom ‚Ü¶ 1, distinguishing ‚Ü¶ +" *forces* the whole
    reading (uniqueness with teeth).  The "forced unfolding" of the corrected thesis, made literal
    for arithmetic. -/
theorem count_reading_forced (g : Raw ‚Üí Nat)
    (ha : g Raw.a = 1) (hb : g Raw.b = 1)
    (hslash : ‚ąÄ (x y : Raw) (h : x ‚Č† y), g (Raw.slash x y h) = g x + g y) :
    ‚ąÄ r : Raw, g r = value r := by
  intro r
  rw [value_eq_leaves]
  exact Lens.view_unique Lens.leaves (fun u v => Nat.add_comm u v) g ha hb hslash r

/-- ‚ėÖ‚ėÖ‚ėÖ **Generation capstone.**  The positive natural `n + 1` is the canonical leaves-Lens reading
    (`Lens.leaves.view`) of the Raw obtained by `n`-fold `slash`-against-`b` (the distinguishing op,
    `succ_is_distinguishing`) from the atom `one = Raw.a`.  ‚Ąē‚āä is the count-Lens reading of iterated
    self-distinguishing ‚ÄĒ the descent leg's leg-1 headline, routed through the *canonical* Lens. -/
theorem generation_capstone (n : Nat) :
    succ (numeral n) = slashOrSelf (numeral n) Raw.b
    ‚ąß Lens.leaves.view (numeral n) = n + 1 :=
  ‚ü®rfl, leaves_numeral n‚ü©

/-! ## ¬ß2 ‚ÄĒ the distinguishing is necessary: distinguishing-blind readings collapse -/

/-- A **distinguishing-blind** reading: the constant combine `fun _ _ => 1` ignores the `slash`
    structure entirely (it never looks at the branches it combines). -/
def degLens : Lens Nat := ‚ü®1, 1, fun _ _ => 1‚ü©

/-- The distinguishing-blind reading collapses *every* Raw to `1` ‚ÄĒ it cannot see the `slash`,
    so it carries no count. -/
theorem deg_view_one (r : Raw) : degLens.view r = 1 := by
  induction r using Raw.rec with
  | a => rfl
  | b => rfl
  | slash x y h _ _ =>
      show Raw.fold 1 1 (fun _ _ => 1) (Raw.slash x y h) = 1
      rw [Raw.fold_slash 1 1 (fun _ _ => 1) (fun _ _ => rfl) x y h]

/-- ‚ėÖ‚ėÖ‚ėÖ **The distinguishing is necessary for the count** (partial rival-exclusion).  The
    distinguishing-blind reading `degLens` maps *all* numerals to one value (`deg_view_one`), so it
    cannot tell `numeral 0` from `numeral 1`; the count ‚ÄĒ which *uses* the distinguishing via `+` ‚ÄĒ
    separates them (`leaves_numeral`: `1 ‚Č† 2`).  So arithmetic is **not** recovered by an arbitrary
    reading of the distinguishing: only a reading that genuinely combines the branches (uses the
    `slash`) generates it.  A reading blind to the distinguishing collapses ‚ÄĒ the structure is
    load-bearing, not decorative. -/
theorem distinguishing_necessary :
    (degLens.view (numeral 0) = degLens.view (numeral 1))
    ‚ąß (Lens.leaves.view (numeral 0) ‚Č† Lens.leaves.view (numeral 1)) := by
  refine ‚ü®by rw [deg_view_one, deg_view_one], ?_‚ü©
  rw [leaves_numeral, leaves_numeral]
  decide

end E213.Lens.Number.Nat213.Generation
