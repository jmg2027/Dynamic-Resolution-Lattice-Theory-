import E213.Lens.Number.Nat213.Raw
import E213.Lens.LensCore
import E213.Lens.Foundations.Initiality

/-!
# Lens.Number.Nat213.Generation тАФ тДХтВК is the leaves-Lens reading of iterated distinguishing (тИЕ-axiom)

The **descent leg**'s generation headline (narrative:
`theory/essays/foundations/raw_and_lens_explained.md`): the
positive naturals are not posited and not merely an "ergonomic parallel" to a Lens form тАФ they are
*generated by the act of distinguishing* and *read off by the canonical leaves-Lens*:

  - the start is the atom: `one := Raw.a`;
  - the successor **is** the distinguishing operation тАФ `succ n := slashOrSelf n Raw.b`
    (`succ_is_distinguishing`), wrapping `n` by a `slash` against the other atom `b`;
  - the count **is** the canonical Lens тАФ `value = Lens.leaves.view` (`value_eq_leaves`), the
    `тЯи1,1,(┬╖+┬╖)тЯй` catamorphism, *not* a bespoke projection (this turns `Raw.lean`'s comment into a
    theorem).

So `Lens.leaves.view (numeral n) = n + 1` (`leaves_numeral`): the positive natural `n+1` is exactly
the canonical leaves-Lens reading of the Raw built by `n`-fold `slash`-against-`b` from the atom `a`.
**тДХтВК = the count-Lens reading of iterated self-distinguishing** тАФ generation, not parallel.  This is
the corrected thesis at the foundation of arithmetic: number is the distinguishing's unfolding, read
by a Lens.  тИЕ-axiom.
-/

namespace E213.Lens.Number.Nat213.Generation

open E213.Theory (Raw)
open E213.Theory.Raw.Endomorphic (slashOrSelf)
open E213.Lens.Number.Nat213.Raw (one succ numeral value value_numeral)
open E213.Lens.Foundations.Initiality

/-- The local leaf-count `value` **is** the canonical leaves-Lens reading
    `Lens.leaves.view` (`Lens.leaves = тЯи1,1,(┬╖+┬╖)тЯй`, the catamorphism).  `Raw.lean`'s comment as a
    theorem: the count is the canonical Lens, not a bespoke projection. -/
theorem value_eq_leaves (r : Raw) : value r = Lens.leaves.view r := rfl

/-- The successor on the Raw chain **is** the act of distinguishing: `succ n` wraps `n` by a `slash`
    against the other atom `b`.  Number's `+1` is a distinguishing event. -/
theorem succ_is_distinguishing (n : Raw) : succ n = slashOrSelf n Raw.b := rfl

/-- The canonical leaves-Lens reading of the `n`-fold iterated distinguishing is `n + 1`. -/
theorem leaves_numeral (n : Nat) : Lens.leaves.view (numeral n) = n + 1 := by
  rw [тЖР value_eq_leaves]; exact value_numeral n

/-- тШЕтШЕтШЕ **The count is the *forced* reading** тАФ initiality (`Lens.view_unique`) at the arithmetic
    level.  *Any* `g : Raw тЖТ Nat` that interprets each atom as `1` and a distinguishing (`slash`) as
    addition is **identically** the leaf-count `value`.  So тДХ-counting is not one choice among
    readings of the distinguishing тАФ fixing "atom тЖж 1, distinguishing тЖж +" *forces* the whole
    reading (uniqueness with teeth).  The "forced unfolding" of the corrected thesis, made literal
    for arithmetic. -/
theorem count_reading_forced (g : Raw тЖТ Nat)
    (ha : g Raw.a = 1) (hb : g Raw.b = 1)
    (hslash : тИА (x y : Raw) (h : x тЙа y), g (Raw.slash x y h) = g x + g y) :
    тИА r : Raw, g r = value r := by
  intro r
  rw [value_eq_leaves]
  exact Lens.view_unique Lens.leaves (fun u v => Nat.add_comm u v) g ha hb hslash r

/-- тШЕтШЕтШЕ **Generation capstone.**  The positive natural `n + 1` is the canonical leaves-Lens reading
    (`Lens.leaves.view`) of the Raw obtained by `n`-fold `slash`-against-`b` (the distinguishing op,
    `succ_is_distinguishing`) from the atom `one = Raw.a`.  тДХтВК is the count-Lens reading of iterated
    self-distinguishing тАФ the descent leg's leg-1 headline, routed through the *canonical* Lens. -/
theorem generation_capstone (n : Nat) :
    succ (numeral n) = slashOrSelf (numeral n) Raw.b
    тИз Lens.leaves.view (numeral n) = n + 1 :=
  тЯиrfl, leaves_numeral nтЯй

/-! ## ┬з2 тАФ the distinguishing is necessary: distinguishing-blind readings collapse -/

/-- A **distinguishing-blind** reading: the constant combine `fun _ _ => 1` ignores the `slash`
    structure entirely (it never looks at the branches it combines). -/
def degLens : Lens Nat := тЯи1, 1, fun _ _ => 1тЯй

/-- The distinguishing-blind reading collapses *every* Raw to `1` тАФ it cannot see the `slash`,
    so it carries no count. -/
theorem deg_view_one (r : Raw) : degLens.view r = 1 := by
  induction r using Raw.rec with
  | a => rfl
  | b => rfl
  | slash x y h _ _ =>
      show Raw.fold 1 1 (fun _ _ => 1) (Raw.slash x y h) = 1
      rw [Raw.fold_slash 1 1 (fun _ _ => 1) (fun _ _ => rfl) x y h]

/-- тШЕтШЕтШЕ **The distinguishing is necessary for the count** (partial rival-exclusion).  The
    distinguishing-blind reading `degLens` maps *all* numerals to one value (`deg_view_one`), so it
    cannot tell `numeral 0` from `numeral 1`; the count тАФ which *uses* the distinguishing via `+` тАФ
    separates them (`leaves_numeral`: `1 тЙа 2`).  So arithmetic is **not** recovered by an arbitrary
    reading of the distinguishing: only a reading that genuinely combines the branches (uses the
    `slash`) generates it.  A reading blind to the distinguishing collapses тАФ the structure is
    load-bearing, not decorative. -/
theorem distinguishing_necessary :
    (degLens.view (numeral 0) = degLens.view (numeral 1))
    тИз (Lens.leaves.view (numeral 0) тЙа Lens.leaves.view (numeral 1)) := by
  refine тЯиby rw [deg_view_one, deg_view_one], ?_тЯй
  rw [leaves_numeral, leaves_numeral]
  decide

end E213.Lens.Number.Nat213.Generation
