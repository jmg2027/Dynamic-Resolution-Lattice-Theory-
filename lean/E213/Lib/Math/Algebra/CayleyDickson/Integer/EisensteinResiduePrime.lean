import E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinResidue
import E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinConverse

/-!
# The residue prime exists unconditionally for `p вүЎ 1 (mod 3)` (rung 2c, вҲ…-axiom)

вҳ…вҳ…вҳ…вҳ…вҳ… `exists_residue_prime` : for a prime `p вүЎ 1 (mod 3)`, there is a **norm-`p` Eisenstein prime**
`d` (`вҖ–dвҖ–ВІ = p`) and a rational integer `x` with `Пү вүЎ x (mod d)`, so that **every** `Оұ вҲҲ в„Ө[Пү]` reduces
mod `d` to the rational integer `Оұ.re + Оұ.imВ·x`:

  `вҲғ d x, вҖ–dвҖ–ВІ = p  вҲ§  вҲҖ Оұ, Оұ вүЎ вҶ‘(Оұ.re + Оұ.imВ·x)  (mod d)`.

This discharges the hypothesis of `EisensteinResidue.reduce_to_int` from primality alone: the cube root
`x` comes from `EisensteinConverse.cube_root_exists` (`p вҲЈ xВІ+x+1`), the norm-`p` prime `d вҲЈ (x вҲ’ Пү)`
from `EisensteinSplit.split_dvd`.  So `в„Ө[Пү]/(d)` is generated by the image of `в„Ө` вҖ” a quotient of
`в„Ө/p` вҖ” completing rung 2 toward the cubic character `(В·/d)вӮғ` (the residue ring is `рқ”Ҫ_p`, where the
character becomes the rational cubic power-residue of `ModArith/CubicResidue`).  вҲ…-axiom (the NatвҶ’в„Ө
cube-root cast reuses the pure pattern of `eisenstein_split_converse`).
-/

namespace E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinResiduePrime

open E213.Lib.Math.Algebra.CayleyDickson.Integer.ZOmega (ZOmega)
open E213.Lib.Math.Algebra.CayleyDickson.Integer.ZOmega.ZOmega
open E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinCongruence (ModEq)
open E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinResidue (exists_residue_prime_int)
open E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinConverse (cube_root_exists three_mul_eq_of_mod)
open E213.Lib.Math.NumberTheory.PolyRoot (nat_dvd_to_int int_dvd_to_nat)
open E213.Tactic.Pow213 (le_of_dvd_pos)

/-- вҳ…вҳ…вҳ…вҳ…вҳ… **The residue prime exists for every prime `p вүЎ 1 (mod 3)`.**  There is a norm-`p`
    Eisenstein prime `d` and a rational integer `x` with `Пү вүЎ x (mod d)`, so every `Оұ вүЎ вҶ‘(Оұ.re +
    Оұ.imВ·x) (mod d)` вҖ” the residue ring `в„Ө[Пү]/(d)` is generated by `в„Ө` (a quotient of `в„Ө/p`), the
    home `рқ”Ҫ_p` of the cubic character.  Cube root from `cube_root_exists`, norm-`p` prime from
    `split_dvd`, propagation from `reduce_to_int`.  вҲ…-axiom. -/
theorem exists_residue_prime (p : Nat) (hp : 1 < p) (hpr : вҲҖ d, d вҲЈ p вҶ’ d = 1 вҲЁ d = p)
    (hmod : p % 3 = 1) :
    вҲғ (d : ZOmega) (x : Int),
      d.normSq = (p : Int) вҲ§ вҲҖ Оұ, ModEq d Оұ (ofInt (Оұ.re + Оұ.im * x)) := by
  obtain вҹЁm, hmвҹ© := three_mul_eq_of_mod p hmod
  obtain вҹЁx, hxвҹ© := cube_root_exists p m hp hpr hm
  have hxcast : ((x * x + x + 1 : Nat) : Int) = (x : Int) * (x : Int) + (x : Int) + 1 := rfl
  have hxint : (p : Int) вҲЈ ((x : Int) * (x : Int) + (x : Int) + 1) := by
    rw [вҶҗ hxcast]; exact nat_dvd_to_int p _ (by rw [Int.natAbs_ofNat]; exact hx)
  have hp1 : В¬ ((p : Int) вҲЈ (1 : Int)) := by
    intro hd
    have hle := le_of_dvd_pos p (Int.natAbs (1 : Int)) (by decide) (int_dvd_to_nat p 1 hd)
    rw [show Int.natAbs (1 : Int) = 1 from rfl] at hle
    exact absurd hle (Nat.not_le.mpr hp)
  obtain вҹЁd, hdn, hd_redвҹ© := exists_residue_prime_int p hp hpr hp1 (x : Int) hxint
  exact вҹЁd, x, hdn, hd_redвҹ©

end E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinResiduePrime
