import E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinSplit
import E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinCongruence

/-!
# `в„Ө[Пү]/(ПҖ)` is generated by `в„Ө` вҖ” reduction to rational integers (rung 2b, вҲ…-axiom)

вҳ…вҳ…вҳ…вҳ… `reduce_to_int` : if `Пү вүЎ r (mod ПҖ)` for a rational integer `r`, then **every** `Оұ вҲҲ в„Ө[Пү]`
is congruent mod `ПҖ` to the rational integer `Оұ.re + Оұ.imВ·r`:

  `Оұ вүЎ вҶ‘(Оұ.re + Оұ.imВ·r)  (mod ПҖ)`.

This is the algebraic heart of the residue-field isomorphism `в„Ө[Пү]/(ПҖ) вү… рқ”Ҫ_p` (rung 2 toward cubic
reciprocity): once `Пү` is congruent to an integer mod `ПҖ` (which holds when `N(ПҖ) = p вүЎ 1 mod 3`,
since then `xВІ + x + 1 вүЎ 0 (mod p)` has a root `r вүЎ Пү` вҖ” `ModArith/EisensteinCubeRoot`), the residue
ring is generated by the image of `в„Ө`, hence is a quotient of `в„Ө/p`.  The cubic character `(Оұ/ПҖ)вӮғ`
thereby reduces to a rational power-residue computation вҖ” the weld to
`ModArith/CubicResidue.cube_iff_three_dvd_dlog`.

The proof is the `в„Ө[Пү] = в„Ө вҠ• в„ӨПү` decomposition (`decomp`) pushed through the congruence: replace the
`Пү` factor by `r` (`EisensteinCongruence.mul_left`), then collapse the rational part with the `ofInt`
ring-hom laws (`ofInt_add`, `ofInt_mul`).  вҲ…-axiom throughout.
-/

namespace E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinResidue

open E213.Lib.Math.Algebra.CayleyDickson.Integer.ZOmega (ZOmega)
open E213.Lib.Math.Algebra.CayleyDickson.Integer.ZOmega.ZOmega
open E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinSplit (ofInt_mul)
open E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinCongruence (ModEq refl add_compat mul_left)
open E213.Meta.Int213 (zero_mul mul_one)
open E213.Meta.Int213 renaming zero_add вҶ’ int_zero_add
open E213.Meta.Int213.Order (sub_zero)

/-- **The `в„Ө[Пү] = в„Ө вҠ• в„ӨПү` decomposition** вҖ” `Оұ = вҶ‘Оұ.re + вҶ‘Оұ.im В· Пү`.  Componentwise: `вҶ‘Оұ.im В· Пү =
    вҹЁ0, Оұ.imвҹ©`, so the sum recovers `вҹЁОұ.re, Оұ.imвҹ©`. -/
theorem decomp (a : ZOmega) : a = ofInt a.re + ofInt a.im * Omega := by
  apply ZOmega.ext
  В· show a.re = a.re + (a.im * 0 - 0 * 1)
    rw [Int.mul_zero, zero_mul, sub_zero, Int.add_zero]
  В· show a.im = 0 + (a.im * 1 + 0 * 0 - 0 * 1)
    rw [mul_one, zero_mul, zero_mul, Int.add_zero, sub_zero, int_zero_add]

/-- `вҶ‘a + вҶ‘b = вҶ‘(a + b)` вҖ” the `ofInt : в„Ө вҶ’ в„Ө[Пү]` embedding is additive (componentwise). -/
theorem ofInt_add (a b : Int) : ofInt a + ofInt b = ofInt (a + b) := by
  apply ZOmega.ext <;> rfl

/-- вҳ…вҳ…вҳ…вҳ… **Reduction to rational integers in `в„Ө[Пү]/(ПҖ)`** вҖ” if `Пү вүЎ r (mod ПҖ)`, every `Оұ` is
    congruent to the rational integer `Оұ.re + Оұ.imВ·r`: `Оұ вүЎ вҶ‘(Оұ.re + Оұ.imВ·r) (mod ПҖ)`.  So the residue
    ring `в„Ө[Пү]/(ПҖ)` is generated by the image of `в„Ө` вҖ” the structural core of `в„Ө[Пү]/(ПҖ) вү… рқ”Ҫ_p`.
    Decomposition `Оұ = вҶ‘Оұ.re + вҶ‘Оұ.imВ·Пү`, then replace `Пү` by `r` through the congruence and collapse
    with `ofInt_mul`/`ofInt_add`.  вҲ…-axiom. -/
theorem reduce_to_int {ПҖ : ZOmega} {r : Int} (h : ModEq ПҖ Omega (ofInt r)) (Оұ : ZOmega) :
    ModEq ПҖ Оұ (ofInt (Оұ.re + Оұ.im * r)) := by
  have hd := decomp Оұ
  have h1 : ModEq ПҖ (ofInt Оұ.im * Omega) (ofInt Оұ.im * ofInt r) := mul_left h (ofInt Оұ.im)
  have h2 := add_compat (refl ПҖ (ofInt Оұ.re)) h1
  rw [вҶҗ ofInt_mul, ofInt_add] at h2
  rw [вҶҗ hd] at h2
  exact h2

end E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinResidue
