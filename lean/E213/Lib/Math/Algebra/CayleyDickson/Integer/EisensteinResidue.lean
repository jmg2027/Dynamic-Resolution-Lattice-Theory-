import E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinSplit
import E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinCongruence

/-!
# `‚Ą§[ŌČ]/(ŌÄ)` is generated by `‚Ą§` ‚ÄĒ reduction to rational integers (rung 2b, ‚ąÖ-axiom)

‚ėÖ‚ėÖ‚ėÖ‚ėÖ `reduce_to_int` : if `ŌČ ‚Č° r (mod ŌÄ)` for a rational integer `r`, then **every** `őĪ ‚ąą ‚Ą§[ŌČ]`
is congruent mod `ŌÄ` to the rational integer `őĪ.re + őĪ.im¬∑r`:

  `őĪ ‚Č° ‚ÜĎ(őĪ.re + őĪ.im¬∑r)  (mod ŌÄ)`.

This is the algebraic heart of the residue-field isomorphism `‚Ą§[ŌČ]/(ŌÄ) ‚ČÖ ūĚĒĹ_p` (rung 2 toward cubic
reciprocity): once `ŌČ` is congruent to an integer mod `ŌÄ` (which holds when `N(ŌÄ) = p ‚Č° 1 mod 3`,
since then `x¬≤ + x + 1 ‚Č° 0 (mod p)` has a root `r ‚Č° ŌČ` ‚ÄĒ `ModArith/EisensteinCubeRoot`), the residue
ring is generated by the image of `‚Ą§`, hence is a quotient of `‚Ą§/p`.  The cubic character `(őĪ/ŌÄ)‚āÉ`
thereby reduces to a rational power-residue computation ‚ÄĒ the weld to
`ModArith/CubicResidue.cube_iff_three_dvd_dlog`.

The proof is the `‚Ą§[ŌČ] = ‚Ą§ ‚äē ‚Ą§ŌČ` decomposition (`decomp`) pushed through the congruence: replace the
`ŌČ` factor by `r` (`EisensteinCongruence.mul_left`), then collapse the rational part with the `ofInt`
ring-hom laws (`ofInt_add`, `ofInt_mul`).  ‚ąÖ-axiom throughout.
-/

namespace E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinResidue

open E213.Lib.Math.Algebra.CayleyDickson.Integer.ZOmega (ZOmega)
open E213.Lib.Math.Algebra.CayleyDickson.Integer.ZOmega.ZOmega
open E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinSplit (ofInt_mul split_dvd)
open E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinCongruence (ModEq refl symm add_compat mul_left)
open E213.Meta.Int213 (zero_mul mul_one)
open E213.Meta.Int213 renaming zero_add ‚Üí int_zero_add
open E213.Meta.Int213.Order (sub_zero)

/-- **The `‚Ą§[ŌČ] = ‚Ą§ ‚äē ‚Ą§ŌČ` decomposition** ‚ÄĒ `őĪ = ‚ÜĎőĪ.re + ‚ÜĎőĪ.im ¬∑ ŌČ`.  Componentwise: `‚ÜĎőĪ.im ¬∑ ŌČ =
    ‚ü®0, őĪ.im‚ü©`, so the sum recovers `‚ü®őĪ.re, őĪ.im‚ü©`. -/
theorem decomp (a : ZOmega) : a = ofInt a.re + ofInt a.im * Omega := by
  apply ZOmega.ext
  ¬∑ show a.re = a.re + (a.im * 0 - 0 * 1)
    rw [Int.mul_zero, zero_mul, sub_zero, Int.add_zero]
  ¬∑ show a.im = 0 + (a.im * 1 + 0 * 0 - 0 * 1)
    rw [mul_one, zero_mul, zero_mul, Int.add_zero, sub_zero, int_zero_add]

/-- `‚ÜĎa + ‚ÜĎb = ‚ÜĎ(a + b)` ‚ÄĒ the `ofInt : ‚Ą§ ‚Üí ‚Ą§[ŌČ]` embedding is additive (componentwise). -/
theorem ofInt_add (a b : Int) : ofInt a + ofInt b = ofInt (a + b) := by
  apply ZOmega.ext <;> rfl

/-- ‚ėÖ‚ėÖ‚ėÖ‚ėÖ **Reduction to rational integers in `‚Ą§[ŌČ]/(ŌÄ)`** ‚ÄĒ if `ŌČ ‚Č° r (mod ŌÄ)`, every `őĪ` is
    congruent to the rational integer `őĪ.re + őĪ.im¬∑r`: `őĪ ‚Č° ‚ÜĎ(őĪ.re + őĪ.im¬∑r) (mod ŌÄ)`.  So the residue
    ring `‚Ą§[ŌČ]/(ŌÄ)` is generated by the image of `‚Ą§` ‚ÄĒ the structural core of `‚Ą§[ŌČ]/(ŌÄ) ‚ČÖ ūĚĒĹ_p`.
    Decomposition `őĪ = ‚ÜĎőĪ.re + ‚ÜĎőĪ.im¬∑ŌČ`, then replace `ŌČ` by `r` through the congruence and collapse
    with `ofInt_mul`/`ofInt_add`.  ‚ąÖ-axiom. -/
theorem reduce_to_int {ŌÄ : ZOmega} {r : Int} (h : ModEq ŌÄ Omega (ofInt r)) (őĪ : ZOmega) :
    ModEq ŌÄ őĪ (ofInt (őĪ.re + őĪ.im * r)) := by
  have hd := decomp őĪ
  have h1 : ModEq ŌÄ (ofInt őĪ.im * Omega) (ofInt őĪ.im * ofInt r) := mul_left h (ofInt őĪ.im)
  have h2 := add_compat (refl ŌÄ (ofInt őĪ.re)) h1
  rw [‚Üź ofInt_mul, ofInt_add] at h2
  rw [‚Üź hd] at h2
  exact h2

/-- The split's divisibility `d ‚ą£ (x ‚ąí ŌČ) = ‚ü®x, ‚ąí1‚ü©` says `ŌČ ‚Č° x (mod d)`: `ModEq d ŌČ ‚ÜĎx`.  (`x ‚ąí ŌČ =
    ‚ÜĎx + ‚ąíŌČ`, so `d ‚ą£ (x ‚ąí ŌČ)` is `ModEq d ‚ÜĎx ŌČ`; symmetry flips it.)  ‚ąÖ-axiom. -/
theorem omega_cong_of_dvd {d : ZOmega} {x : Int} (h : d ‚ą£ (‚ü®x, -1‚ü© : ZOmega)) :
    ModEq d Omega (ofInt x) := by
  have key : (‚ü®x, -1‚ü© : ZOmega) = ofInt x + -Omega := by
    apply ZOmega.ext
    ¬∑ show x = x + -(0 : Int)
      rw [Int.neg_zero, Int.add_zero]
    ¬∑ show (-1 : Int) = 0 + -(1 : Int)
      rw [int_zero_add]
  have h2 : d ‚ą£ (ofInt x + -Omega) := key ‚Ėł h
  exact symm h2

/-- ‚ėÖ‚ėÖ‚ėÖ‚ėÖ **The residue prime, given a cube root** ‚ÄĒ for a prime `p` with `p ‚ą£ x¬≤+x+1` (`x ‚Č° ŌČ`), there
    is a norm-`p` Eisenstein prime `d` with `ŌČ ‚Č° x (mod d)`, hence (by `reduce_to_int`) **every** `őĪ ‚ąą
    ‚Ą§[ŌČ]` reduces mod `d` to the rational integer `őĪ.re + őĪ.im¬∑x`.  `split_dvd` gives `d ‚ą£ (x ‚ąí ŌČ)`,
    `omega_cong_of_dvd` reads it as `ŌČ ‚Č° x`, and `reduce_to_int` propagates it.  ‚ąÖ-axiom. -/
theorem exists_residue_prime_int (p : Nat) (hp2 : 2 ‚Č§ p) (hpr : ‚ąÄ m, m ‚ą£ p ‚Üí m = 1 ‚ą® m = p)
    (hp1 : ¬¨ ((p : Int) ‚ą£ (1 : Int))) (x : Int) (hx : (p : Int) ‚ą£ (x * x + x + 1)) :
    ‚ąÉ d : ZOmega, d.normSq = (p : Int) ‚ąß ‚ąÄ őĪ, ModEq d őĪ (ofInt (őĪ.re + őĪ.im * x)) := by
  obtain ‚ü®d, hdn, hdŌČ‚ü© := split_dvd p hp2 hpr hp1 x hx
  exact ‚ü®d, hdn, fun őĪ => reduce_to_int (omega_cong_of_dvd hdŌČ) őĪ‚ü©

end E213.Lib.Math.Algebra.CayleyDickson.Integer.EisensteinResidue
