theorem g_vals_at_22 :
    g1 i2 i2 m0 = false ∧ g2 i2 i2 m0 = false ∧ g3 i2 i2 m0 = false ∧
    g4 i2 i2 m0 = false ∧ g5 i2 i2 m0 = false ∧ g6 i2 i2 m0 = true ∧
    g7 i2 i2 m0 = false ∧ g8 i2 i2 m0 = false := by
  refine ⟨?_, ?_, ?_, ?_, ?_, ?_, ?_, ?_⟩ <;> decide

/-! ## §8 — Per-position candidate equation

For each face position `(s, t)`, prove `candidate v s t m0 = v s t m0`.
Cases (0,0), (2,0), (1,0) require Bool reasoning; (1,0) additionally
uses `ψ_0(v) = false`.  The remaining 6 positions are trivial (only
one generator contributes). -/

/-- Bool identity: at the (0,0) position the candidate reduces to a
    three-variable XOR equation whose pure-Bool form yields the target.
    All 8 v-position arguments must appear because the goal has them
    syntactically; the irrelevant ones are absorbed by `_ && false`. -/
private theorem bool_id_00 (a b c d3 d4 d5 d6 d8 : Bool) :
    xor (a && true) (xor (b && true) (xor (d3 && false) (xor (d4 && false)
      (xor (d5 && false) (xor (d6 && false)
        (xor ((xor (xor c a) b) && true) (d8 && false))))))) = c := by
  cases a <;> cases b <;> cases c <;> cases d3 <;> cases d4 <;>
    cases d5 <;> cases d6 <;> cases d8 <;> rfl

/-- Helper: unfold candidate + scaled + g-values into a Bool expression
    for position `(s, t)`.  Each rewrite chain is identical except for
    the `g_vals_at_*` lemma used. -/
private theorem candidate_unfold (v : EnrichedFaceVal 1) (s t : Fin 3) :
    candidate v s t m0 =
      xor ((b1_of v) && g1 s t m0)
       (xor ((b2_of v) && g2 s t m0)
        (xor ((b3_of v) && g3 s t m0)
         (xor ((b4_of v) && g4 s t m0)
          (xor ((b5_of v) && g5 s t m0)
           (xor ((b6_of v) && g6 s t m0)
            (xor ((b7_of v) && g7 s t m0) ((b8_of v) && g8 s t m0))))))) := by
  unfold candidate
  rw [scaled_val (b1_of v) g1, scaled_val (b2_of v) g2,
      scaled_val (b3_of v) g3, scaled_val (b4_of v) g4,
      scaled_val (b5_of v) g5, scaled_val (b6_of v) g6,
      scaled_val (b7_of v) g7, scaled_val (b8_of v) g8]

theorem candidate_at_00 (v : EnrichedFaceVal 1) :
    candidate v i0 i0 m0 = v i0 i0 m0 := by
  rw [candidate_unfold v i0 i0]
  obtain ⟨h1, h2, h3, h4, h5, h6, h7, h8⟩ := g_vals_at_00
  rw [h1, h2, h3, h4, h5, h6, h7, h8]
  unfold b1_of b2_of b3_of b4_of b5_of b6_of b7_of b8_of
  exact bool_id_00 (v i0 i1 m0) (v i0 i2 m0) (v i0 i0 m0)
    (v i1 i1 m0) (v i1 i2 m0) (v i2 i1 m0) (v i2 i2 m0)
    (xor (xor (v i2 i0 m0) (v i2 i1 m0)) (v i2 i2 m0))

/-- Position (0,1): only g_1 contributes (`g1(0,1) = true`, others false).
    The active coefficient is `b1_of v = v(0,1)`. -/
theorem candidate_at_01 (v : EnrichedFaceVal 1) :
    candidate v i0 i1 m0 = v i0 i1 m0 := by
  rw [candidate_unfold v i0 i1]
  obtain ⟨h1, h2, h3, h4, h5, h6, h7, h8⟩ := g_vals_at_01
  rw [h1, h2, h3, h4, h5, h6, h7, h8]
  unfold b1_of b2_of b3_of b4_of b5_of b6_of b7_of b8_of
  cases v i0 i0 m0 <;> cases v i0 i1 m0 <;> cases v i0 i2 m0 <;>
    cases v i1 i1 m0 <;> cases v i1 i2 m0 <;>
    cases v i2 i0 m0 <;> cases v i2 i1 m0 <;> cases v i2 i2 m0 <;> rfl

/-- Position (0,2): only g_2 contributes; active coefficient `b2_of v = v(0,2)`. -/
theorem candidate_at_02 (v : EnrichedFaceVal 1) :
    candidate v i0 i2 m0 = v i0 i2 m0 := by
  rw [candidate_unfold v i0 i2]
  obtain ⟨h1, h2, h3, h4, h5, h6, h7, h8⟩ := g_vals_at_02
  rw [h1, h2, h3, h4, h5, h6, h7, h8]
  unfold b1_of b2_of b3_of b4_of b5_of b6_of b7_of b8_of
  cases v i0 i0 m0 <;> cases v i0 i1 m0 <;> cases v i0 i2 m0 <;>
    cases v i1 i1 m0 <;> cases v i1 i2 m0 <;>
    cases v i2 i0 m0 <;> cases v i2 i1 m0 <;> cases v i2 i2 m0 <;> rfl

/-- Position (1,1): only g_3 contributes; active coefficient `b3_of v = v(1,1)`. -/
theorem candidate_at_11 (v : EnrichedFaceVal 1) :
    candidate v i1 i1 m0 = v i1 i1 m0 := by
  rw [candidate_unfold v i1 i1]
  obtain ⟨h1, h2, h3, h4, h5, h6, h7, h8⟩ := g_vals_at_11
  rw [h1, h2, h3, h4, h5, h6, h7, h8]
  unfold b1_of b2_of b3_of b4_of b5_of b6_of b7_of b8_of
  cases v i0 i0 m0 <;> cases v i0 i1 m0 <;> cases v i0 i2 m0 <;>
    cases v i1 i1 m0 <;> cases v i1 i2 m0 <;>
    cases v i2 i0 m0 <;> cases v i2 i1 m0 <;> cases v i2 i2 m0 <;> rfl

/-- Position (1,2): only g_4 contributes; active coefficient `b4_of v = v(1,2)`. -/
theorem candidate_at_12 (v : EnrichedFaceVal 1) :
    candidate v i1 i2 m0 = v i1 i2 m0 := by
  rw [candidate_unfold v i1 i2]
  obtain ⟨h1, h2, h3, h4, h5, h6, h7, h8⟩ := g_vals_at_12
  rw [h1, h2, h3, h4, h5, h6, h7, h8]
  unfold b1_of b2_of b3_of b4_of b5_of b6_of b7_of b8_of
  cases v i0 i0 m0 <;> cases v i0 i1 m0 <;> cases v i0 i2 m0 <;>
    cases v i1 i1 m0 <;> cases v i1 i2 m0 <;>
    cases v i2 i0 m0 <;> cases v i2 i1 m0 <;> cases v i2 i2 m0 <;> rfl

/-- Position (2,1): only g_5 contributes; active coefficient `b5_of v = v(2,1)`. -/
theorem candidate_at_21 (v : EnrichedFaceVal 1) :
    candidate v i2 i1 m0 = v i2 i1 m0 := by
  rw [candidate_unfold v i2 i1]
  obtain ⟨h1, h2, h3, h4, h5, h6, h7, h8⟩ := g_vals_at_21
  rw [h1, h2, h3, h4, h5, h6, h7, h8]
  unfold b1_of b2_of b3_of b4_of b5_of b6_of b7_of b8_of
  cases v i0 i0 m0 <;> cases v i0 i1 m0 <;> cases v i0 i2 m0 <;>
    cases v i1 i1 m0 <;> cases v i1 i2 m0 <;>
    cases v i2 i0 m0 <;> cases v i2 i1 m0 <;> cases v i2 i2 m0 <;> rfl

/-- Position (2,2): only g_6 contributes; active coefficient `b6_of v = v(2,2)`. -/
theorem candidate_at_22 (v : EnrichedFaceVal 1) :
    candidate v i2 i2 m0 = v i2 i2 m0 := by
  rw [candidate_unfold v i2 i2]
  obtain ⟨h1, h2, h3, h4, h5, h6, h7, h8⟩ := g_vals_at_22
  rw [h1, h2, h3, h4, h5, h6, h7, h8]
  unfold b1_of b2_of b3_of b4_of b5_of b6_of b7_of b8_of
  cases v i0 i0 m0 <;> cases v i0 i1 m0 <;> cases v i0 i2 m0 <;>
    cases v i1 i1 m0 <;> cases v i1 i2 m0 <;>
    cases v i2 i0 m0 <;> cases v i2 i1 m0 <;> cases v i2 i2 m0 <;> rfl

/-- Position (2,0): generators g_5, g_6, g_8 contribute; analogous to
    `candidate_at_00` with row 2 in place of row 0. -/
theorem candidate_at_20 (v : EnrichedFaceVal 1) :
    candidate v i2 i0 m0 = v i2 i0 m0 := by
  rw [candidate_unfold v i2 i0]
  obtain ⟨h1, h2, h3, h4, h5, h6, h7, h8⟩ := g_vals_at_20
  rw [h1, h2, h3, h4, h5, h6, h7, h8]
  unfold b1_of b2_of b3_of b4_of b5_of b6_of b7_of b8_of
  cases v i0 i0 m0 <;> cases v i0 i1 m0 <;> cases v i0 i2 m0 <;>
    cases v i1 i1 m0 <;> cases v i1 i2 m0 <;>
    cases v i2 i0 m0 <;> cases v i2 i1 m0 <;> cases v i2 i2 m0 <;> rfl

/-- Helper: re-express `psi_layer 1 m0 v` using the `i0/i1/i2/m0` aliases. -/
theorem psi_layer_one_eq (v : EnrichedFaceVal 1) :
    psi_layer 1 m0 v =
      xor (xor (xor (xor (xor (xor (xor (xor
        (v i0 i0 m0) (v i0 i1 m0)) (v i0 i2 m0))
        (v i1 i0 m0)) (v i1 i1 m0)) (v i1 i2 m0))
        (v i2 i0 m0)) (v i2 i1 m0)) (v i2 i2 m0) := rfl

-- Bool identity for position (1, 0): the only case requiring `ψ_0 = false`.
-- Cases where the antecedent is impossible (`true = false`) are
-- dismissed by `absurd`; the satisfiable cases reduce to `rfl`.
set_option maxHeartbeats 1600000 in
private theorem bool_id_10
    (v00 v01 v02 v10 v11 v12 v20 v21 v22 : Bool)
    (hpsi : xor (xor (xor (xor (xor (xor (xor (xor
      v00 v01) v02) v10) v11) v12) v20) v21) v22 = false) :
    xor (v01 && false) (xor (v02 && false) (xor (v11 && true)
      (xor (v12 && true) (xor (v21 && false) (xor (v22 && false)
        (xor ((xor (xor v00 v01) v02) && true)
             ((xor (xor v20 v21) v22) && true))))))) = v10 := by
  cases v00 <;> cases v01 <;> cases v02 <;> cases v10 <;> cases v11 <;>
    cases v12 <;> cases v20 <;> cases v21 <;> cases v22 <;>
    first | rfl | exact absurd hpsi (by decide)

/-- Position (1,0): the structural case requiring `ψ_0(v) = false`.
    Generators g_3, g_4, g_7, g_8 all contribute; the decomposition
    is equivalent to `v(1,0) = sum_of_others`, which is exactly the
    ψ_0-kernel condition. -/
theorem candidate_at_10 (v : EnrichedFaceVal 1)
    (hpsi : psi_layer 1 m0 v = false) :
    candidate v i1 i0 m0 = v i1 i0 m0 := by
  rw [candidate_unfold v i1 i0]
  obtain ⟨h1, h2, h3, h4, h5, h6, h7, h8⟩ := g_vals_at_10
  rw [h1, h2, h3, h4, h5, h6, h7, h8]
  unfold b1_of b2_of b3_of b4_of b5_of b6_of b7_of b8_of
  rw [psi_layer_one_eq] at hpsi
  exact bool_id_10 (v i0 i0 m0) (v i0 i1 m0) (v i0 i2 m0) (v i1 i0 m0)
    (v i1 i1 m0) (v i1 i2 m0) (v i2 i0 m0) (v i2 i1 m0) (v i2 i2 m0) hpsi

/-! ## §9 — Capstone: pointwise equality and HARD direction at c = 1

Bundle the 9 per-position equations into pointwise equality
`candidate v = v` (for any (s, t, m')); then `cong` lifts the
established `InPrimary 1 (candidate v)` to `InPrimary 1 v`. -/

theorem candidate_eq_pointwise (v : EnrichedFaceVal 1)
    (hpsi : psi_layer 1 m0 v = false)
    (s t : Fin 3) (m' : Fin 1) :
    candidate v s t m' = v s t m' := by
  match m' with
  | ⟨0, _⟩ =>
    match s, t with
    | ⟨0, _⟩, ⟨0, _⟩ => exact candidate_at_00 v
    | ⟨0, _⟩, ⟨1, _⟩ => exact candidate_at_01 v
    | ⟨0, _⟩, ⟨2, _⟩ => exact candidate_at_02 v
    | ⟨1, _⟩, ⟨0, _⟩ => exact candidate_at_10 v hpsi
    | ⟨1, _⟩, ⟨1, _⟩ => exact candidate_at_11 v
    | ⟨1, _⟩, ⟨2, _⟩ => exact candidate_at_12 v
    | ⟨2, _⟩, ⟨0, _⟩ => exact candidate_at_20 v
    | ⟨2, _⟩, ⟨1, _⟩ => exact candidate_at_21 v
    | ⟨2, _⟩, ⟨2, _⟩ => exact candidate_at_22 v
    | ⟨n+3, h⟩, _ => exfalso; exact absurd (Nat.le_add_left 3 n) (Nat.not_le_of_lt h)
    | _, ⟨n+3, h⟩ => exfalso; exact absurd (Nat.le_add_left 3 n) (Nat.not_le_of_lt h)
  | ⟨n+1, h⟩ => exfalso; exact absurd (Nat.le_add_left 1 n) (Nat.not_le_of_lt h)

/-- **HARD direction at c = 1**: every face cochain `v : EnrichedFaceVal 1`
    with `ψ_0(v) = false` lies in `InPrimaryCupSpanPlusBoundary 1`.

    Constructed via the 8-generator decomposition + cong constructor. -/
theorem joint_psi_kernel_subset_primary_c1 (v : EnrichedFaceVal 1)
    (hpsi : psi_layer 1 m0 v = false) :
    InPrimaryCupSpanPlusBoundary 1 v :=
  InPrimaryCupSpanPlusBoundary.cong v (candidate v)
    (fun s t m' => (candidate_eq_pointwise v hpsi s t m').symm)
    (candidate_in_primary v)

end E213.Lib.Math.Cohomology.Bipartite.V33EnrichedParametricDualSpanHard
