/-! ## В§1.  Each reading equals 6 (as a Nat or Int identity) -/

/-- Reading 1: ZOmega unit count = 6.  -/
theorem reading_1_eisenstein_units : units6.length = 6 := units_count_eq_six

/-- Reading 2: NS В· NT atomicity product = 6.  -/
theorem reading_2_atomicity_product : NS * NT = 6 := by decide

/-- Reading 3: d + 1 = 6 (successor of atomicity).  -/
theorem reading_3_d_plus_one : d + 1 = 6 := by decide

/-- Reading 4: 3! = Sym(3) order = Pauli Оө non-zero entries = 6.  -/
theorem reading_4_three_factorial : 3 * 2 * 1 = 6 := by decide

/-- Reading 5: SU(NS) simple root count = NS В· (NS вҲ’ 1) = 6.  -/
theorem reading_5_su3_roots : NS * (NS - 1) = 6 := by decide

/-- Reading 6: K_{NS,NT} SвҖ“T cross-pair count at c = 1 = 6.  -/
theorem reading_6_K32_cross_pairs : NS * NT = 6 := by decide

/-- Reading 7: SO(3, 1) Lorentz generator count = ((d вҲ’ 1)(d вҲ’ 2))/2 = 6.
    The d = 5 ambient вҶ’ 4-Minkowski slice вҶ’ 4В·3/2 = 6.  -/
theorem reading_7_lorentz_generators : ((d - 1) * (d - 2)) / 2 = 6 := by decide

/-- Reading 8: О”вҒҙ + K_{3,2}^{(c=2)} ПҮ-sum = вҲ’6.  -/
theorem reading_8_chi_sum :
    chi_delta_4 + chi_K_32_c2 = -((NS : Int) * NT) := by
