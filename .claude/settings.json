{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/purity-guard.sh",
            "timeout": 10,
            "statusMessage": "DRLT 213 purity check..."
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/layer-import-guard.sh",
            "timeout": 5,
            "statusMessage": "Layer-import discipline check..."
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/.claude/hooks/no-legacy-narration.py",
            "timeout": 5,
            "statusMessage": "Legacy-narration / G## guard..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/no-amend.sh",
            "timeout": 5,
            "statusMessage": "Checking git amend/force..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/kernel-axiom-check.sh",
            "timeout": 60,
            "statusMessage": "Kernel axiom regression check..."
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/size-guard.sh",
            "timeout": 5,
            "statusMessage": "CLAUDE.md size discipline check..."
          }
        ]
      }
    ]
  }
}
